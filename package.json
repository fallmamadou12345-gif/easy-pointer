{
  "name": "easy-pointer",
  "version": "1.0.0",
  "description": "Easy Pointer - Système de gestion du temps de présence avec géofencing",
  "main": "server/index.js",
  "scripts": {
    "install:all": "npm install && cd client && npm install",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "dev:server": "nodemon server/index.js",
    "dev:client": "cd client && npm run dev",
    "render:build": "npm install && cd client && npm install && npm run build",
    "render:start": "node server/index.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
